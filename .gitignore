# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# fonts (large binary files - generate locally with pyftsubset or download from Google Fonts)
# ただし PDF 生成サーバーが読み込む NotoSansJP.ttf だけは本番でも必要なのでコミットする。
/public/fonts/*
!/public/fonts/NotoSansJP.ttf
